generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OwnerType {
  SELF
  SPOUSE
  FAMILY
}

enum AssetClass {
  MUTUAL_FUND
  STOCK
  EPF
  NPS
  BANK
  SAVINGS
  FIXED_DEPOSIT
  RECURRING_DEPOSIT
  GOLD
  SGB
  DIGITAL_GOLD
  GOLD_ETF
  REAL_ESTATE
  PHYSICAL_PLOT
  LIC
  ULIP
  PPF
  BOND
  ETF
  PMS
  AIF
  ESOP
  RSU
  PENSION
  VEHICLE
  COMMODITY
  CRYPTO
  OTHER
}

enum LiabilityClass {
  HOME_LOAN
  PERSONAL_LOAN
  CREDIT_CARD
  CAR_LOAN
  OTHER
}

enum LiquidityCategory {
  HIGH
  MEDIUM
  LOW
}

enum ImportType {
  GENERIC_CSV
  KUVERA
  CAS
  ZERODHA
  BANK
  EPF
  NPS
}

enum TransactionType {
  BUY
  SELL
  DIVIDEND
  INTEREST
  CONTRIBUTION
  PREMIUM
  EMI
  ADJUSTMENT
}

enum DataSourceProvider {
  ZERODHA
  CAS
  NSE
  LIC
  EPFO
  NPS
  LAND_RECORDS
  ACCOUNT_AGGREGATOR
  MANUAL
}

enum DataSourceStatus {
  NOT_CONNECTED
  CONNECTED
  SYNCED
  ERROR
  CONFIG_REQUIRED
}

enum DataSourceAuthType {
  OAUTH
  API_TOKEN
  FILE_UPLOAD
  MANUAL
  CONSENT
  LICENSED_FEED
}

enum AdvisorContextKind {
  HOLDING
  MARKET_PRICE
  MF_PORTFOLIO
  DEBT_LIQUIDITY
  VALUATION_NOTE
  WARNING
  CONNECTOR_STATUS
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  sessions      Session[]
  owners        Owner[]
  institutions  Institution[]
  assets        Asset[]
  liabilities   Liability[]
  goals         Goal[]
  imports       ImportBatch[]
  reports       Report[]
  aiInsights    AiInsight[]
  dataSources    DataSource[]
  syncRuns       SyncRun[]
  instruments    Instrument[]
  advisorContext AdvisorContextItem[]
  auditLogs     AuditLog[]
}

model Owner {
  id          String    @id @default(cuid())
  userId      String
  name        String
  type        OwnerType
  assets      Asset[]
  liabilities Liability[]
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Institution {
  id          String      @id @default(cuid())
  userId      String?
  name        String
  type        String
  assets      Asset[]
  liabilities Liability[]
  createdAt   DateTime    @default(now())
  user        User?       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Asset {
  id                String             @id @default(cuid())
  userId            String
  ownerId           String?
  institutionId     String?
  ownerType         OwnerType          @default(SELF)
  assetClass        AssetClass
  name              String
  platform          String?
  investedAmount    Decimal            @db.Decimal(14, 2)
  currentValue      Decimal            @db.Decimal(14, 2)
  units             Decimal?           @db.Decimal(18, 6)
  currentPrice      Decimal?           @db.Decimal(14, 4)
  purchaseDate      DateTime?
  contributionDate  DateTime?
  notes             String?
  tags              String[]           @default([])
  liquidity         LiquidityCategory   @default(MEDIUM)
  taxCategory       String?
  schemeCategory    String?
  folioMasked       String?
  sipAmount         Decimal?           @db.Decimal(12, 2)
  lockIn            Boolean            @default(false)
  symbol            String?
  exchange          String?
  sector            String?
  metadata          Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  owner             Owner?             @relation(fields: [ownerId], references: [id])
  institution       Institution?       @relation(fields: [institutionId], references: [id])
  snapshots         AssetSnapshot[]
  transactions      Transaction[]

  @@index([userId, assetClass])
  @@index([ownerId])
}

model AssetSnapshot {
  id           String   @id @default(cuid())
  assetId      String
  snapshotDate DateTime
  investedValue Decimal @db.Decimal(14, 2)
  currentValue Decimal  @db.Decimal(14, 2)
  units        Decimal? @db.Decimal(18, 6)
  price        Decimal? @db.Decimal(14, 4)
  notes        String?
  createdAt    DateTime @default(now())
  asset        Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, snapshotDate])
}

model Liability {
  id                String         @id @default(cuid())
  userId            String
  ownerId           String?
  institutionId     String?
  ownerType         OwnerType      @default(SELF)
  liabilityClass    LiabilityClass
  lender            String
  name              String
  originalAmount    Decimal        @db.Decimal(14, 2)
  outstandingAmount Decimal        @db.Decimal(14, 2)
  emi               Decimal?       @db.Decimal(12, 2)
  interestRate      Decimal?       @db.Decimal(6, 3)
  remainingTenureMonths Int?
  startDate         DateTime?
  endDate           DateTime?
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  owner             Owner?         @relation(fields: [ownerId], references: [id])
  institution       Institution?   @relation(fields: [institutionId], references: [id])
  snapshots         LiabilitySnapshot[]

  @@index([userId, liabilityClass])
}

model LiabilitySnapshot {
  id                String    @id @default(cuid())
  liabilityId       String
  snapshotDate      DateTime
  outstandingAmount Decimal   @db.Decimal(14, 2)
  notes             String?
  createdAt         DateTime  @default(now())
  liability         Liability @relation(fields: [liabilityId], references: [id], onDelete: Cascade)

  @@unique([liabilityId, snapshotDate])
}

model Transaction {
  id              String          @id @default(cuid())
  userId          String
  assetId         String?
  transactionDate DateTime
  assetName       String
  transactionType TransactionType @default(ADJUSTMENT)
  amount          Decimal         @db.Decimal(14, 2)
  units           Decimal?        @db.Decimal(18, 6)
  price           Decimal?        @db.Decimal(14, 4)
  sourceHash      String?
  notes           String?
  createdAt       DateTime        @default(now())
  asset           Asset?          @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@unique([userId, sourceHash])
  @@index([userId, transactionDate])
}

model ImportBatch {
  id             String     @id @default(cuid())
  userId         String
  importType     ImportType
  fileName       String
  rowCount       Int
  importedCount  Int        @default(0)
  duplicateCount Int        @default(0)
  status         String     @default("PREVIEWED")
  mapping        Json?
  createdAt      DateTime   @default(now())
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id                       String   @id @default(cuid())
  userId                   String
  name                     String
  targetAmount             Decimal  @db.Decimal(14, 2)
  targetDate               DateTime?
  currentMappedAmount      Decimal  @db.Decimal(14, 2) @default(0)
  expectedReturnPercentage Decimal? @db.Decimal(6, 3)
  notes                    String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AiInsight {
  id                    String   @id @default(cuid())
  userId                String
  portfolioSnapshotJson Json
  recommendationsJson   Json
  riskScore             Int?
  status                String   @default("COMPLETED")
  createdAt             DateTime @default(now())
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports               Report[]

  @@index([userId, createdAt])
}

model DataSource {
  id          String             @id @default(cuid())
  userId      String
  provider    DataSourceProvider
  name        String
  status      DataSourceStatus   @default(NOT_CONNECTED)
  authType    DataSourceAuthType
  lastSyncAt  DateTime?
  metadata    Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncRuns    SyncRun[]
  contextItems AdvisorContextItem[]

  @@unique([userId, provider])
  @@index([userId, status])
}

model SyncRun {
  id             String             @id @default(cuid())
  userId         String
  dataSourceId   String
  provider       DataSourceProvider
  status         DataSourceStatus
  importedCount  Int                @default(0)
  updatedCount   Int                @default(0)
  warningCount   Int                @default(0)
  errorMessage    String?
  warnings       Json?
  startedAt      DateTime           @default(now())
  completedAt    DateTime?
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  dataSource     DataSource         @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@index([dataSourceId, startedAt])
}

model Instrument {
  id          String             @id @default(cuid())
  userId      String?
  symbol      String?
  isin        String?
  name        String
  exchange    String?
  assetClass  AssetClass
  metadata    Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  quotes      MarketQuote[]

  @@index([userId, assetClass])
  @@index([symbol])
  @@index([isin])
}

model MarketQuote {
  id           String   @id @default(cuid())
  instrumentId String
  price        Decimal  @db.Decimal(14, 4)
  currency     String   @default("INR")
  source       String
  asOfDate     DateTime
  metadata     Json?
  createdAt    DateTime @default(now())
  instrument   Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)

  @@index([instrumentId, asOfDate])
  @@index([source, asOfDate])
}

model AdvisorContextItem {
  id           String             @id @default(cuid())
  userId       String
  dataSourceId String?
  kind         AdvisorContextKind
  title        String
  source       String
  asOfDate     DateTime
  confidence   Decimal            @db.Decimal(5, 2)
  staleness    String
  payload      Json
  createdAt    DateTime           @default(now())
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  dataSource   DataSource?        @relation(fields: [dataSourceId], references: [id], onDelete: SetNull)

  @@index([userId, kind])
  @@index([userId, asOfDate])
  @@index([dataSourceId])
}

model Report {
  id          String     @id @default(cuid())
  userId      String
  aiInsightId String?
  type        String
  periodStart DateTime
  periodEnd   DateTime
  contentJson Json
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiInsight   AiInsight? @relation(fields: [aiInsightId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}
